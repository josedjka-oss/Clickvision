# URL pública del sitio (metadata, sitemap, Open Graph). En local se usa http://localhost:3000 por defecto.
NEXT_PUBLIC_SITE_URL=https://www.tudominio.com

# Firebase (consola: Project settings → Your apps → Web)
# Solo claves públicas; endurecer con reglas de Firestore/Storage y App Check.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Authentication: en Firebase Console → Authentication → Sign-in method, activa "Correo/contraseña".

# Panel admin: correos separados por coma (misma cuenta que Firebase Auth). Refuerza con reglas Firestore/Storage.
NEXT_PUBLIC_ADMIN_EMAILS=

# Firestore: colección `products` (documento id libre; campo `slug` único recomendado).
# `published: false` oculta del catálogo. Campos requeridos alineados con `Product` + mock en `src/features/catalog/data/mock-products.ts`.

# --- Producción ---
# Copia este archivo a .env.local (local) o define las mismas claves en el panel del host (Vercel, etc.).
# Tras cambiar NEXT_PUBLIC_* en el host, hace falta un nuevo build/despliegue.
# NODE_ENV la fija el propio Next en build/start; no hace falta definirla a mano salvo entornos Docker personalizados.

# Sistema visual (colores, tipografía, componentes): docs/sistema-diseno.md
